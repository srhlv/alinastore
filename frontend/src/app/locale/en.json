  "faq": {
    "title": "FAQ",
    "items": [
      {
        "q": "How do I place an order?",
        "a": "Pick an artwork in the gallery, add the format you want to the cart, and leave your contact details at checkout. I will then get in touch with you."
      },
      {
        "q": "Is there online payment?",
        "a": "No. The site does not take payments. We agree on payment and shipping personally after the order."
      },
      {
        "q": "What about shipping?",
        "a": "Shipping within Ukraine and abroad is arranged individually depending on the format (original or print)."
      },
      {
        "q": "Can I commission a custom piece?",
        "a": "Yes. Write via Telegram or email — we can discuss the idea, size, and timeline."
      }
    ]
