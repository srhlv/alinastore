# Copy to .env and fill in values from Supabase dashboard → Connect
#
# IMPORTANT: On most home/office networks use the Session pooler (IPv4), NOT direct connection.
# Dashboard → Connect → Session mode → copy URI
#
# Session pooler (recommended for local dev):
# DATABASE_URL=postgresql://postgres.prfbmhfnsjmfwfewebob:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
#
# Direct connection (IPv6 only on free tier — often fails locally):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.prfbmhfnsjmfwfewebob.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/postgres

JWT_SECRET=change-me-to-a-long-random-string
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
